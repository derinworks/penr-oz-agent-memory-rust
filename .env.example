# ── Qdrant ────────────────────────────────────────────────────────────────────
# Host port for the Qdrant REST API (default: 6333)
QDRANT_PORT=6333

# Host port for the Qdrant gRPC interface (default: 6334)
QDRANT_GRPC_PORT=6334

# API key for Qdrant (leave empty for unauthenticated local instances)
# Required when connecting to Qdrant Cloud or any auth-enabled deployment.
# Also set in config.toml → [qdrant] api_key, or override via this variable.
QDRANT_API_KEY=

# ── Ollama (optional – only used with --profile ollama) ───────────────────────
# Host port for the Ollama API (default: 11434)
OLLAMA_PORT=11434

# ── Application ───────────────────────────────────────────────────────────────
# API key required for session endpoints (X-Api-Key header).
# Leave empty to disable authentication on session endpoints.
SESSION_API_KEY=

# ── Embedding providers ───────────────────────────────────────────────────────
# OpenAI API key (needed when embedding.default_provider = "openai")
OPENAI_API_KEY=

# Anthropic API key (needed when embedding.default_provider = "claude")
ANTHROPIC_API_KEY=
